# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/brief_collector?schema=public"

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
TURNSTILE_SITE_KEY="your-turnstile-site-key"

# Admin Auth
# Generate base64 hash:
#   node -e "require('bcryptjs').hash('yourpassword',12).then(h=>console.log(Buffer.from(h).toString('base64')))"
ADMIN_PASSWORD_HASH="<base64-encoded-bcrypt-hash>"
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-64-char-hex-secret"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
